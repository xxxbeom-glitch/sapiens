# Google Gemini — 파이프라인 요약·시황·탭 분류 LLM (google-genai)
# GEMINI_API_KEY 또는 GOOGLE_API_KEY 중 하나
GEMINI_API_KEY=your_key_here
# Gemini 3.1 Flash-Lite(텍스트/JSON 요약용). 미설정 시에도 코드 기본값 동일.
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# 서비스 계정: 하나만 설정 (우선순위: B64 > 평문 JSON > 파일 경로)
# FIREBASE_SERVICE_ACCOUNT_B64=<service-account.json 을 base64 인코딩한 값>
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceaccount.json
DATABASE_ID=sapiens

# 선택: 기사 JSON을 단일 요약 루프(SAPIENS_ARTICLE_LLM_JUDGE)로만 돌릴지 (1=활성)
# SAPIENS_ARTICLE_LLM_JUDGE=1

# 선택: 마켓(지표·테마·업종·시황 요약·Firestore market/*). 미설정·0이면 비활성(기본)
# SAPIENS_MARKET_PIPELINE=1
