# Anthropic (Claude Haiku) — 파이프라인 요약·시황·탭 분류 LLM에 필수
ANTHROPIC_API_KEY=your_key_here
# 선택: 다른 Haiku/소닉 모델 ID로 덮어쓰기 (기본 claude-3-5-haiku-20241022)
# CLAUDE_MODEL=claude-3-5-haiku-20241022

# 서비스 계정: 하나만 설정 (우선순위: B64 > 평문 JSON > 파일 경로)
# FIREBASE_SERVICE_ACCOUNT_B64=<service-account.json 을 base64 인코딩한 값>
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceaccount.json
DATABASE_ID=sapiens

# 선택: 기사 JSON을 단일 요약 루프(SAPIENS_ARTICLE_LLM_JUDGE)로만 돌릴지 (1=활성)
# SAPIENS_ARTICLE_LLM_JUDGE=1
